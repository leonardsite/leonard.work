{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash(*)",
      "Agent(*)",
      "Skill(*)",
      "NotebookEdit",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*"
    ],
    "deny": []
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
